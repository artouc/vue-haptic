{
  "version": "0.0.1",
  "tasks": {
    "dev": "deno run -A --node-modules-dir npm:vite --host",
    "build": "deno run -A --node-modules-dir npm:vite build",
    "preview": "deno run -A --node-modules-dir npm:vite preview",
    "serve": "deno run --allow-net --allow-read jsr:@std/http@1/file-server dist/"
  },
  "compilerOptions": {
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "jsxImportSource": "react",
    "jsxImportSourceTypes": "@types/react"
  },
  "nodeModulesDir": "auto",
  "imports": {
    "react": "npm:react@^19.1.0",
    "react-dom": "npm:react-dom@^19.1.0",
    "use-haptic": "../../src/mod.ts",
    "vite": "npm:vite@^6.0.1",
    "vite-plugin-qrcode": "npm:vite-plugin-qrcode@^0.2.3",
    "@types/react": "npm:@types/react@^19.1.0",
    "@types/react-dom": "npm:@types/react-dom@^19.1.2",
    "@deno/vite-plugin": "npm:@deno/vite-plugin@^1.0.0",
    "@vitejs/plugin-react-swc": "npm:@vitejs/plugin-react-swc@^3.7.1"
  },
  "deploy": {
    "project": "27435cf6-854d-4fbb-9505-2719b02b08ad",
    "exclude": ["**/node_modules"],
    "include": [],
    "entrypoint": "jsr:@std/http@1.0.0-rc.5/file-server"
  }
}
